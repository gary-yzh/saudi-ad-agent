# Copy to .env and fill in.
# If ANTHROPIC_API_KEY is unset, the agent automatically runs in offline-mock mode
# (deterministic stub responses for every LLM call) so the demo still runs end-to-end.

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Mock toggles for the three Seed APIs. "1" = mock, "0" = call real (not implemented).
SEEDREAM_MOCK=1
SEEDANCE_MOCK=1
SEED_SPEECH_MOCK=1
